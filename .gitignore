# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# IDE / editor
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# Ignore everything by default, but keep the non-secret, environment-specific
# API URLs in source. Personal/secret overrides go in *.local and stay ignored.
.env*
.env.development
.env.production
!.env.example

# vercel
.vercel
